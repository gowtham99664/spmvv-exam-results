# Prebuilt frontend image — expects build/ to already exist on the host.
# Run: npm install && npm run build   (on the host, NOT inside Docker)
# Then: docker build -f Dockerfile.prebuilt -t spmvv-frontend .
FROM nginx:alpine

COPY build /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 2026

CMD ["nginx", "-g", "daemon off;"]
